# ============================================================================
# Environment Configuration - yolo-object-detection
# ============================================================================

# ---- Model ----
MODEL_PATH=models/best.pt
ONNX_PATH=models/best.onnx
MODEL_VARIANT=yolov8l  # yolov8n, yolov8s, yolov8m, yolov8l, yolov8x
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# ---- Training ----
EPOCHS=100
BATCH_SIZE=16
IMG_SIZE=640
N_CLASSES=10
DATASET_PATH=data/wafer_defects
SEED=42

# ---- Triton Inference ----
TRITON_URL=localhost:8001
TRITON_MODEL_NAME=yolov8
TRITON_MODEL_VERSION=1

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8080
AUTH_ENABLED=true
API_KEY=change-me-in-production
JWT_SECRET=change-me-use-long-random-string
RATE_LIMIT_PER_MINUTE=60

# ---- Cache ----
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=300

# ---- Monitoring ----
PROMETHEUS_PORT=9090
MLFLOW_TRACKING_URI=http://localhost:5000

# ---- Hardware ----
CUDA_VISIBLE_DEVICES=0
DEVICE=cuda  # cuda, cpu, mps

LOG_LEVEL=INFO
